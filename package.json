{
  "name": "@nandan-varma/git-edge",
  "version": "0.1.2",
  "description": "High-level edge-compatible git operations — parsed-object cache, object-level three-way merge, and repo management utilities. Composes with @nandan-varma/git-fs-s3.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "git",
    "isomorphic-git",
    "edge",
    "serverless",
    "merge",
    "cache",
    "three-way-merge"
  ],
  "author": "Nandan Varma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nandan-varma/git-edge.git"
  },
  "bugs": {
    "url": "https://github.com/nandan-varma/git-edge/issues"
  },
  "homepage": "https://github.com/nandan-varma/git-edge#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "lru-cache": "^11.2.1"
  },
  "peerDependencies": {
    "@nandan-varma/git-fs-s3": ">=0.3.0",
    "isomorphic-git": ">=1.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@nandan-varma/git-fs-s3": "^0.3.0",
    "@types/node": "^22.15.21",
    "isomorphic-git": "^1.27.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
